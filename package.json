{
    "name": "@stephenr85/rjsf-splicewire",
    "version": "0.1.0",
    "description": "The Splicewire adapter over rjsf-registry: the vendored x-* generation-vocabulary meta-schema (sync-grammar pattern), the Splicewire keyword dialect configured onto the shell, and the pre-wired SplicewireForm.",
    "license": "MIT",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "src",
        "grammar",
        "README.md"
    ],
    "publishConfig": {
        "registry": "https://npm.pkg.github.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/stephenr85/rjsf-splicewire.git"
    },
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run",
        "typecheck": "tsc --noEmit",
        "sync-grammar": "node scripts/sync-grammar.mjs",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "@stephenr85/rjsf-registry": "^0.1.0"
    },
    "peerDependencies": {
        "@rjsf/core": "^6.0.0",
        "@rjsf/shadcn": "^6.0.0",
        "@rjsf/utils": "^6.0.0",
        "@rjsf/validator-ajv8": "^6.0.0",
        "react": ">=18"
    },
    "devDependencies": {
        "@rjsf/core": "^6.0.0",
        "@rjsf/shadcn": "^6.0.0",
        "@rjsf/utils": "^6.0.0",
        "@rjsf/validator-ajv8": "^6.0.0",
        "@testing-library/react": "^16.1.0",
        "@types/node": "^26.1.1",
        "@types/react": "^19.0.0",
        "jsdom": "^26.0.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "tsup": "^8.5.1",
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
    }
}
